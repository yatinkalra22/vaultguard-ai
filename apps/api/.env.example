# ======================
# VaultGuard AI — Backend (NestJS)
# ======================
# Copy this file to: apps/api/.env
# Setup guide: docs/BACKEND_ENV_SETUP.md

# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth0 ─────────────────────────────────────────────────
AUTH0_DOMAIN=              # YOUR_TENANT.us.auth0.com
AUTH0_AUDIENCE=https://api.vaultguard.ai

# ── Auth0 AI (Token Vault + CIBA) ─────────────────────────
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ── Auth0 FGA ─────────────────────────────────────────────
FGA_STORE_ID=
FGA_CLIENT_ID=
FGA_CLIENT_SECRET=

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=              # https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Claude AI) ─────────────────────────────────
ANTHROPIC_API_KEY=         # sk-ant-...

# ── URLs ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
AUTH0_BASE_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────
DEFAULT_GITHUB_ORG=        # Fallback GitHub org for scheduled/manual scans
